DATABASE_URL=postgresql://postgres:123@localhost:5432/rent_soft_db
# If you use a hosted provider (Render/Neon/Aiven/etc) it may require TLS/SSL.
# - Option A: set DATABASE_SSL=true
# - Option B: append ?sslmode=require to DATABASE_URL
DATABASE_SSL=
# If your provider uses a self-signed cert (not typical), set to false.
DATABASE_SSL_REJECT_UNAUTHORIZED=
# Alternative to DATABASE_SSL: set PGSSLMODE=require (or disable).
PGSSLMODE=
PORT=4000
TRUST_PROXY=
FORCE_HTTPS=
COOKIE_SECURE=true
SESSION_IDLE_DAYS=
ALLOWED_REDIRECT_HOSTS=
ALLOWED_HTTP_METHODS=GET,HEAD,POST,PUT,DELETE,OPTIONS
DEV_PORTAL_PASSWORD=
DEV_PORTAL_SESSION_TTL_MS=
SECURITY_HEADERS_DISABLED=
CONTENT_SECURITY_POLICY=
HSTS_MAX_AGE=15552000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=
JSON_BODY_LIMIT=5mb
UPLOAD_ROOT=
IMAGE=
IMAGE_URL_BASE=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEOCODE_USER_AGENT=RentSoft/0.1 (you@example.com)
GEOCODE_TIMEOUT_MS=15000
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GOOGLE_MAPS_API_KEY=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_ALLOWED_REDIRECT_PATHS=/settings.html,/customers.html,/invoices.html,/qbo-customers.html
QBO_ENV=sandbox
QBO_MINOR_VERSION=75
QBO_DOC_NUMBER_MODE=rental
QBO_REVOKE_URL=
QBO_WEBHOOK_VERIFIER_TOKEN=
QBO_TOKEN_ENCRYPTION_KEY=
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=200

# Recurring work orders
# - When enabled, the server periodically checks for recurring work orders whose due date has arrived
#   and creates a new work order occurrence.
RECURRING_WORK_ORDERS_ENABLED=true
RECURRING_WORK_ORDER_SWEEP_MS=300000
